-- ===== ARROWS ESP =====
-- Drawing library triangles for off-screen targets
local ArrowsESP = {}
do
	local arrowPool = {}
	local enabled = false
	local teamFilter = true
	
	-- Arrow configuration
	local ArrowColor = Color3.new(1, 1, 1)
	local ArrowSize = 12
	local ArrowTransparency = 0

	ArrowsESP.Enabled = enabled

	local function clampToScreen(pos, padding)
		local viewport = Camera.ViewportSize
		return Vector2.new(
			math.clamp(pos.X, padding, viewport.X - padding),
			math.clamp(pos.Y, padding, viewport.Y - padding)
		)
	end

	local function createArrow()
		local triangle = Drawing.new("Triangle")
		triangle.Visible = false
		triangle.Color = ArrowColor
		triangle.Filled = true
		triangle.Thickness = 2
		triangle.Transparency = ArrowTransparency
		return triangle
	end

	local function updateArrows()
		if not enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
			return
		end

		-- Clean up arrows for players who left
		for uid, arrow in pairs(arrowPool) do
			if not ConcurrentPlayers[uid] then
				arrow:Destroy()
				arrowPool[uid] = nil
			end
		end

		local viewport = Camera.ViewportSize
		local center = viewport / 2

		-- Update arrows for active players
		for uid, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Check team filter
			if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Get target position and check if on screen
			local targetPos = player.Character.HumanoidRootPart.Position
			local screenPos, onScreen = Camera:WorldToScreenPoint(targetPos)
			local screenPos2D = Vector2.new(screenPos.X, screenPos.Y)

			local arrow = arrowPool[uid]
			if not arrow then
				arrow = createArrow()
				arrowPool[uid] = arrow
			end
			
			if not onScreen then
				local dir = screenPos2D - center
				if screenPos.Z < 0 then
					dir = -dir
				end
				dir = dir.Unit

				-- Position arrow at fixed distance from center
				local arrowDist = math.min(center.X, center.Y) - 25
				local arrowPos = center + dir * arrowDist
				arrowPos = clampToScreen(arrowPos, ArrowSize + 10)	

				-- Calculate angle for triangle rotation
				local angle = math.atan2(dir.Y, dir.X)

				-- Draw triangle pointing towards target
				arrow.PointA = arrowPos + Vector2.new(
					math.cos(angle) * ArrowSize,
					math.sin(angle) * ArrowSize
				)
				arrow.PointB = arrowPos + Vector2.new(
					math.cos(angle + math.rad(140)) * ArrowSize,
					math.sin(angle + math.rad(140)) * ArrowSize
				)
				arrow.PointC = arrowPos + Vector2.new(
					math.cos(angle - math.rad(140)) * ArrowSize,
					math.sin(angle - math.rad(140)) * ArrowSize
				)

				arrow.Color = ArrowColor
				arrow.Visible = true

				print("Arrow for " .. player.Name .. " at " .. tostring(arrowPos))
			else
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:Toggle(state)
		enabled = state
		ArrowsESP.Enabled = enabled
		if not enabled then
			for _, arrow in pairs(arrowPool) do
				arrow.Visible = false
			end
		end
		print("Arrows ESP toggled " .. tostring(state))
	end

	function ArrowsESP:SetTeamFilter(state)
		teamFilter = not not state
	end

	function ArrowsESP:SetColor(r, g, b)
		ArrowColor = Color3.new(r, g, b)
		for _, arrow in pairs(arrowPool) do
			arrow.Color = ArrowColor
		end
	end

	function ArrowsESP:SetSize(size)
		ArrowSize = size
	end

	function ArrowsESP:SetTransparency(val)
		ArrowTransparency = math.clamp(val, 0, 1)
		for _, arrow in pairs(arrowPool) do
			arrow.Transparency = ArrowTransparency
		end
	end

	ArrowsESP.Connection = RunService.RenderStepped:Connect(updateArrows)
end

-- ===== CHAMS ESP ===== (unchanged)
local ChamsESP = {}
do
	local chamFolder = Instance.new("Folder")
	chamFolder.Name = "Op1Hax_Chams"
	chamFolder.Parent = CoreGui

	local chamCache = {}
	local enabled = false
	local teamFilter = true
	local outlineColor = Color3.new(1, 1, 1)
	local outlineTransparency = 0.8

	ChamsESP.Enabled = enabled

	local function createCham(player)
		if not player.Character then return end
		if chamCache[player] then return end

		local highlight = Instance.new("Highlight")
		highlight.Adornee = player.Character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 1
		highlight.OutlineColor = outlineColor
		highlight.OutlineTransparency = outlineTransparency
		highlight.Parent = chamFolder

		chamCache[player] = highlight
	end

	local function removeCham(player)
		if chamCache[player] then
			chamCache[player]:Destroy()
			chamCache[player] = nil
		end
	end

	local function updateChams()
		if not enabled or not LocalPlayer.Character then return end

		for _, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then
				removeCham(player)
			else
				if player.Character then
					if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
						removeCham(player)
					else
						createCham(player)
					end
				else
					removeCham(player)
				end
			end
		end
	end

	function ChamsESP:Toggle(state)
		enabled = state
		ChamsESP.Enabled = enabled
		if not enabled then
			for player in pairs(chamCache) do
				removeCham(player)
			end
		end
		print("Chams ESP toggled " .. tostring(state))
	end

	function ChamsESP:SetTeamFilter(state)
		teamFilter = not not state
		updateChams()
	end

	function ChamsESP:SetColor(r, g, b)
		outlineColor = Color3.new(r, g, b)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineColor = outlineColor
		end
	end

	function ChamsESP:SetTransparency(val)
		outlineTransparency = math.clamp(val, 0, 1)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineTransparency = outlineTransparency
		end
	end

	ChamsESP.UpdateConnection = RunService.Heartbeat:Connect(updateChams)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.P then
		ArrowsESP:Toggle(not ArrowsESP.Enabled)
	elseif input.KeyCode == Enum.KeyCode.L then
		ChamsESP:Toggle(true)
		task.wait(1)
		ChamsESP:Toggle(false)
	end
end)

