-- ===== ARROWS ESP =====
-- Minimap-style arrows at bottom center of screen in a circle
local ArrowsESP = {}
do
	local minimapGui = Instance.new("ScreenGui")
	minimapGui.Name = "Op1Hax_ArrowsESP"
	minimapGui.ResetOnSpawn = false
	minimapGui.Parent = CoreGui

	local minimapContainer = Instance.new("Frame")
	minimapContainer.Name = "MinimapContainer"
	minimapContainer.Size = UDim2.fromScale(0.067, 0.067)
	minimapContainer.Position = UDim2.new(0.5, 0, 0.9, 0)
	minimapContainer.AnchorPoint = Vector2.new(0.5, 0.5)
	minimapContainer.BackgroundColor3 = Color3.new(0, 0, 0)
	minimapContainer.BackgroundTransparency = 0.9
	minimapContainer.BorderSizePixel = 0
	minimapContainer.Parent = minimapGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = minimapContainer

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.new(1, 1, 1)
	stroke.Thickness = 2
	stroke.Transparency = 0.5
	stroke.Parent = minimapContainer

	local arrowPool = {}
	local arrowRadius = 70
	local enabled = true
	local teamFilter = true

	ArrowsESP.Enabled = enabled

	local function createArrow(uid)
		local arrow = Instance.new("TextLabel")
		arrow.Name = "Arrow_" .. uid
		arrow.Size = UDim2.fromOffset(24, 24)
		arrow.BackgroundTransparency = 1
		arrow.Text = "▲"
		arrow.Font = Enum.Font.GothamBlack
		arrow.TextSize = 20
		arrow.TextColor3 = Color3.new(1, 1, 1) -- Red for enemies
		arrow.AnchorPoint = Vector2.new(0.5, 0.5)
		arrow.Visible = false
		arrow.Parent = minimapContainer
		return arrow
	end

	local function hideAllArrows()
		for _, arrow in pairs(arrowPool) do
			arrow.Visible = false
		end
	end

	local function updateArrows()
		if not enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or not Camera then
			hideAllArrows()
			return
		end

		for uid, arrow in pairs(arrowPool) do
			if not ConcurrentPlayers[uid] then
				arrow:Destroy()
				arrowPool[uid] = nil
			end
		end

		local localHRP = LocalPlayer.Character.HumanoidRootPart
		local localPos = localHRP.Position * Vector3.new(1, 0, 1)

		local camLook = Camera.CFrame.LookVector
		local camFwdXZ = camLook * Vector3.new(1, 0, 1)
		local camFwdMag = camFwdXZ.Magnitude
		if camFwdMag < 1e-6 then
			hideAllArrows()
			return
		end
		camFwdXZ = camFwdXZ.Unit
		local angle_cam = math.atan2(camFwdXZ.Z, camFwdXZ.X)

		for uid, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			local targetHRP = player.Character.HumanoidRootPart
			local targetPos = targetHRP.Position * Vector3.new(1, 0, 1)
			local diff = targetPos - localPos
			local diffMag = diff.Magnitude
			if diffMag < 5 then  -- Hide if too close
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Valid target: compute camera-relative direction
			local dirXZ = diff.Unit
			local angle_dir = math.atan2(dirXZ.Z, dirXZ.X)
			local relative = angle_dir - angle_cam
			relative = ((relative + math.pi) % (math.pi * 2)) - math.pi  -- Normalize to -pi..pi
			local screen_theta = relative - math.pi / 2  -- Rotate so forward (0) is at top

			local x = math.cos(screen_theta) * arrowRadius
			local y = math.sin(screen_theta) * arrowRadius

			local arrow = arrowPool[uid]
			if not arrow then
				arrow = createArrow(uid)
				arrowPool[uid] = arrow
			end

			arrow.Position = UDim2.fromOffset(100 + x, 100 + y)
			arrow.Rotation = math.deg(screen_theta) + 90
			arrow.Visible = true
		end
	end

	function ArrowsESP:Toggle(state)
		enabled = not not state
		ArrowsESP.Enabled = enabled
		if not enabled then
			hideAllArrows()
		end
	end

	function ArrowsESP:SetTeamFilter(state)
		teamFilter = not not state
	end

	ArrowsESP.Connection = RunService.RenderStepped:Connect(updateArrows)
end

-- ===== CHAMS ESP ===== (unchanged)
local ChamsESP = {}
do
	local chamFolder = Instance.new("Folder")
	chamFolder.Name = "Op1Hax_Chams"
	chamFolder.Parent = CoreGui

	local chamCache = {}
	local enabled = true
	local teamFilter = true
	local outlineColor = Color3.new(1, 1, 1)
	local outlineTransparency = 0.2

	ChamsESP.Enabled = enabled

	local function createCham(player)
		if not player.Character then return end
		if chamCache[player] then return end

		local highlight = Instance.new("Highlight")
		highlight.Adornee = player.Character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 1
		highlight.OutlineColor = outlineColor
		highlight.OutlineTransparency = outlineTransparency
		highlight.Parent = chamFolder

		chamCache[player] = highlight
	end

	local function removeCham(player)
		if chamCache[player] then
			chamCache[player]:Destroy()
			chamCache[player] = nil
		end
	end

	local function updateChams()
		if not enabled or not LocalPlayer.Character then return end

		for _, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then
				removeCham(player)
			else
				if player.Character then
					if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
						removeCham(player)
					else
						createCham(player)
					end
				else
					removeCham(player)
				end
			end
		end
	end

	function ChamsESP:Toggle(state)
		enabled = state
		ChamsESP.Enabled = enabled
		if not enabled then
			for player in pairs(chamCache) do
				removeCham(player)
			end
		end
	end

	function ChamsESP:SetTeamFilter(state)
		teamFilter = not not state
		updateChams()
	end

	function ChamsESP:SetColor(r, g, b)
		outlineColor = Color3.new(r, g, b)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineColor = outlineColor
		end
	end

	function ChamsESP:SetTransparency(val)
		outlineTransparency = math.clamp(val, 0, 1)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineTransparency = outlineTransparency
		end
	end

	ChamsESP.UpdateConnection = RunService.Heartbeat:Connect(updateChams)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.P then
		ArrowsESP:Toggle(not ArrowsESP.Enabled)
	elseif input.KeyCode == Enum.KeyCode.L then
		ChamsESP:Toggle(true)
		task.wait(1)
		ChamsESP:Toggle(false)
	end
end)