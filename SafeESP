-- ===== ARROWS ESP =====
-- Drawing library-based arrows pointing to off-screen targets
local ArrowsESP = {}
do
	local arrowPool = {}
	local enabled = false
	local teamFilter = true
	
	-- Arrow configuration
	local DistFromCenter = 10
	local TriangleHeight = 5
	local TriangleWidth = 5
	local TriangleFilled = true
	local TriangleTransparency = 0
	local TriangleThickness = 1
	local TriangleColor = Color3.new(1, 1, 1)

	ArrowsESP.Enabled = enabled

	local function createArrow()
		local triangle = Drawing.new("Triangle")
		triangle.Visible = false
		triangle.Color = TriangleColor
		triangle.Filled = TriangleFilled
		triangle.Thickness = TriangleThickness
		triangle.Transparency = 1 - TriangleTransparency
		return triangle
	end

	local function rotateVector(v, angle)
		angle = math.rad(angle)
		local cos_a = math.cos(angle)
		local sin_a = math.sin(angle)
		return Vector2.new(v.x * cos_a - v.y * sin_a, v.x * sin_a + v.y * cos_a)
	end

	local function getRelative(targetPos, playerChar)
		if not playerChar or not playerChar:FindFirstChild("HumanoidRootPart") then
			return Vector3.new(0, 0, 0)
		end
		local playerPos = playerChar.HumanoidRootPart.Position
		local relative = Camera.CFrame:PointToObjectSpace(targetPos)
		return Vector3.new(relative.X, relative.Y, relative.Z)
	end

	local function relativeToCenter(v)
		return Camera.ViewportSize / 2 - v
	end

	local function updateArrows()
		if not enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
			return
		end

		-- Clean up arrows for players who left
		for uid, arrow in pairs(arrowPool) do
			if not ConcurrentPlayers[uid] then
				arrow:Destroy()
				arrowPool[uid] = nil
			end
		end

		-- Update arrows for active players
		for uid, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Check team filter
			if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Get target position and check if on screen
			local targetPos = player.Character.HumanoidRootPart.Position
			local onScreen, screenPos = Camera:WorldToViewportPoint(targetPos)

			local arrow = arrowPool[uid]
			if not arrow then
				arrow = createArrow()
				arrowPool[uid] = arrow
			end

			if not onScreen then
				-- Target is off-screen, draw arrow pointing towards it
				local rel = getRelative(targetPos, LocalPlayer.Character)
				local direction = Vector2.new(rel.X, rel.Z).Unit
				
				-- Calculate triangle points
				local base = direction * DistFromCenter
				local sideLength = TriangleWidth / 2
				local baseL = base + rotateVector(direction, 90) * sideLength
				local baseR = base + rotateVector(direction, -90) * sideLength
				local tip = direction * (DistFromCenter + TriangleHeight)

				-- Position relative to screen center
				local centerOffset = relativeToCenter(Vector2.new(0, 0))
				arrow.PointA = relativeToCenter(baseL) + centerOffset
				arrow.PointB = relativeToCenter(baseR) + centerOffset
				arrow.PointC = relativeToCenter(tip) + centerOffset
				arrow.Visible = true
			else
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:Toggle(state)
		enabled = state
		ArrowsESP.Enabled = enabled
		if not enabled then
			for _, arrow in pairs(arrowPool) do
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:SetTeamFilter(state)
		teamFilter = not not state
	end

	function ArrowsESP:SetColor(r, g, b)
		TriangleColor = Color3.new(r, g, b)
		for _, arrow in pairs(arrowPool) do
			arrow.Color = TriangleColor
		end
	end

	function ArrowsESP:SetDistance(dist)
		DistFromCenter = dist
	end

	ArrowsESP.Connection = RunService.RenderStepped:Connect(updateArrows)
end

-- ===== CHAMS ESP ===== (unchanged)
local ChamsESP = {}
do
	local chamFolder = Instance.new("Folder")
	chamFolder.Name = "Op1Hax_Chams"
	chamFolder.Parent = CoreGui

	local chamCache = {}
	local enabled = false
	local teamFilter = true
	local outlineColor = Color3.new(1, 1, 1)
	local outlineTransparency = 0.8

	ChamsESP.Enabled = enabled

	local function createCham(player)
		if not player.Character then return end
		if chamCache[player] then return end

		local highlight = Instance.new("Highlight")
		highlight.Adornee = player.Character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 1
		highlight.OutlineColor = outlineColor
		highlight.OutlineTransparency = outlineTransparency
		highlight.Parent = chamFolder

		chamCache[player] = highlight
	end

	local function removeCham(player)
		if chamCache[player] then
			chamCache[player]:Destroy()
			chamCache[player] = nil
		end
	end

	local function updateChams()
		if not enabled or not LocalPlayer.Character then return end

		for _, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then
				removeCham(player)
			else
				if player.Character then
					if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
						removeCham(player)
					else
						createCham(player)
					end
				else
					removeCham(player)
				end
			end
		end
	end

	function ChamsESP:Toggle(state)
		enabled = state
		ChamsESP.Enabled = enabled
		if not enabled then
			for player in pairs(chamCache) do
				removeCham(player)
			end
		end
	end

	function ChamsESP:SetTeamFilter(state)
		teamFilter = not not state
		updateChams()
	end

	function ChamsESP:SetColor(r, g, b)
		outlineColor = Color3.new(r, g, b)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineColor = outlineColor
		end
	end

	function ChamsESP:SetTransparency(val)
		outlineTransparency = math.clamp(val, 0, 1)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineTransparency = outlineTransparency
		end
	end

	ChamsESP.UpdateConnection = RunService.Heartbeat:Connect(updateChams)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.P then
		ArrowsESP:Toggle(not ArrowsESP.Enabled)
	elseif input.KeyCode == Enum.KeyCode.L then
		ChamsESP:Toggle(true)
		task.wait(1)
		ChamsESP:Toggle(false)
	end
end)
