-- ===== ARROWS ESP =====
-- Drawing library triangles for off-screen targets
local ArrowsESP = {}
do
	local arrowPool = {}
	local enabled = false
	local teamFilter = true

	local ArrowColor = Color3.new(1, 1, 1)

	ArrowsESP.Enabled = enabled

	local Folder = Instance.new('Folder')
	Folder.Name = "Op1Hax_ArrowsESP"
	Folder.Parent = CoreGui

	if not isfolder("Op1Hax") then
		makefolder("Op1Hax")
	end

	if not isfile("Op1Hax/Arrow.png") then
		writefile("Op1Hax/Arrow.png", game:HttpGet("https://raw.githubusercontent.com/7GrandDadPGN/VapeV4ForRoblox/refs/heads/main/assets/new/arrowmodule.png"))
	end

	local function createArrow()
		local arrow = Instance.new('ImageLabel')
		arrow.Size = UDim2.fromOffset(256, 256)
		arrow.Position = UDim2.fromScale(0.5, 0.5)
		arrow.AnchorPoint = Vector2.new(0.5, 0.5)
		arrow.BackgroundTransparency = 1
		arrow.BorderSizePixel = 0
		arrow.Visible = false
		arrow.Image = getcustomasset("Op1Hax/Arrow.png")
		arrow.ImageColor3 = ArrowColor
		arrow.Parent = Folder
		return arrow
	end

	local function updateArrows()
		if not enabled then return end
		if not LocalPlayer.Character then return end
		if not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

		for uid, arrow in pairs(arrowPool) do
			if not ConcurrentPlayers[uid] then
				arrow:Destroy()
				arrowPool[uid] = nil
			end
		end

		for uid, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then continue end
			if not player.Character then continue end

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			if teamFilter and LocalPlayer.Team == player.Team then
				if arrowPool[uid] then arrowPool[uid].Visible = false end
				continue
			end

			local arrow = arrowPool[player.UserId]
			if not arrow then
				arrow = createArrow()
				arrowPool[player.UserId] = arrow
			end

			local _, onScreen = Camera:WorldToScreenPoint(player.Character.HumanoidRootPart.Position)

			if not onScreen then
				local dir = CFrame.lookAlong(Camera.CFrame.Position, Camera.CFrame.LookVector * Vector3.new(1, 0, 1)):PointToObjectSpace(player.Character.HumanoidRootPart.Position)
				arrow.Rotation = math.deg(math.atan2(dir.Z, dir.X))
				
				arrow.Visible = true
			else
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:Toggle(state)
		enabled = state
		ArrowsESP.Enabled = enabled
		if not enabled then
			for _, arrow in pairs(arrowPool) do
				arrow.Visible = false
			end
		end
		print("Arrows ESP toggled " .. tostring(state))
	end

	function ArrowsESP:SetTeamFilter(state)
		teamFilter = not not state
	end

	function ArrowsESP:SetColor(r, g, b)
		ArrowColor = Color3.new(r, g, b)
		for _, arrow in pairs(arrowPool) do
			arrow.Color = ArrowColor
		end
	end

	function ArrowsESP:SetSize(size)
		ArrowSize = size
	end

	function ArrowsESP:SetTransparency(val)
		ArrowTransparency = math.clamp(val, 0, 1)
		for _, arrow in pairs(arrowPool) do
			arrow.Transparency = ArrowTransparency
		end
	end

	ArrowsESP.Connection = RunService.RenderStepped:Connect(updateArrows)
end

-- ===== CHAMS ESP ===== (unchanged)
local ChamsESP = {}
do
	local chamFolder = Instance.new("Folder")
	chamFolder.Name = "Op1Hax_Chams"
	chamFolder.Parent = CoreGui

	local chamCache = {}
	local enabled = false
	local teamFilter = true
	local outlineColor = Color3.new(1, 1, 1)
	local outlineTransparency = 0.8

	ChamsESP.Enabled = enabled

	local function createCham(player)
		if not player.Character then return end
		if chamCache[player] then return end

		local highlight = Instance.new("Highlight")
		highlight.Adornee = player.Character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 1
		highlight.OutlineColor = outlineColor
		highlight.OutlineTransparency = outlineTransparency
		highlight.Parent = chamFolder

		chamCache[player] = highlight
	end

	local function removeCham(player)
		if chamCache[player] then
			chamCache[player]:Destroy()
			chamCache[player] = nil
		end
	end

	local function updateChams()
		if not enabled or not LocalPlayer.Character then return end

		for _, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then
				removeCham(player)
			else
				if player.Character then
					if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
						removeCham(player)
					else
						createCham(player)
					end
				else
					removeCham(player)
				end
			end
		end
	end

	function ChamsESP:Toggle(state)
		enabled = state
		ChamsESP.Enabled = enabled
		if not enabled then
			for player in pairs(chamCache) do
				removeCham(player)
			end
		end
		print("Chams ESP toggled " .. tostring(state))
	end

	function ChamsESP:SetTeamFilter(state)
		teamFilter = not not state
		updateChams()
	end

	function ChamsESP:SetColor(r, g, b)
		outlineColor = Color3.new(r, g, b)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineColor = outlineColor
		end
	end

	function ChamsESP:SetTransparency(val)
		outlineTransparency = math.clamp(val, 0, 1)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineTransparency = outlineTransparency
		end
	end

	ChamsESP.UpdateConnection = RunService.Heartbeat:Connect(updateChams)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.P then
		ArrowsESP:Toggle(not ArrowsESP.Enabled)
	elseif input.KeyCode == Enum.KeyCode.L then
		ChamsESP:Toggle(true)
		task.wait(1)
		ChamsESP:Toggle(false)
	end
end)

