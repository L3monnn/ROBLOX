-- ===== ARROWS ESP =====
-- Drawing library-based arrows pointing to off-screen targets
local ArrowsESP = {}
do
	local arrowPool = {}
	local enabled = false
	local teamFilter = true
	
	-- Arrow configuration
	local ArrowColor = Color3.new(1, 1, 1)
	local ArrowSize = 40
	local ArrowDistance = 150

	ArrowsESP.Enabled = enabled

	local function createArrow()
		local text = Drawing.new("Text")
		text.Visible = false
		text.Color = ArrowColor
		text.Size = ArrowSize
		text.Font = 2
		text.Text = "▲"
		text.Center = true
		text.Transparency = 0.5
		return text
	end

	local function updateArrows()
		if not enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
			return
		end

		-- Clean up arrows for players who left
		for uid, arrow in pairs(arrowPool) do
			if not ConcurrentPlayers[uid] then
				arrow:Destroy()
				arrowPool[uid] = nil
			end
		end

		local localChar = LocalPlayer.Character
		local localHRP = localChar.HumanoidRootPart
		local screenCenter = Camera.ViewportSize / 2
		local camCFrame = Camera.CFrame
		local camLook = camCFrame.LookVector

		-- Get camera's forward direction in XZ plane
		local camForward = Vector3.new(camLook.X, 0, camLook.Z).Unit
		local camAngle = math.atan2(camForward.Z, camForward.X)

		-- Update arrows for active players
		for uid, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Check team filter
			if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
				local arrow = arrowPool[uid]
				if arrow then
					arrow.Visible = false
				end
				continue
			end

			-- Get target position and check if on screen
			local targetPos = player.Character.HumanoidRootPart.Position
			local onScreen, screenPos = Camera:WorldToViewportPoint(targetPos)
			print(onScreen, screenPos)

			local arrow = arrowPool[uid]
			if not arrow then
				arrow = createArrow()
				arrowPool[uid] = arrow
			end

			if not onScreen then
				-- Calculate direction to target in XZ plane
				local localPos = localHRP.Position
				local targetXZ = Vector3.new(targetPos.X, 0, targetPos.Z)
				local localXZ = Vector3.new(localPos.X, 0, localPos.Z)
				local dirXZ = (targetXZ - localXZ).Unit
				local targetAngle = math.atan2(dirXZ.Z, dirXZ.X)
				
				-- Calculate relative angle to camera
				local relativeAngle = targetAngle - camAngle
				relativeAngle = ((relativeAngle + math.pi) % (math.pi * 2)) - math.pi

				-- Position arrow at distance from center
				local arrowX = math.cos(relativeAngle) * ArrowDistance
				local arrowY = math.sin(relativeAngle) * ArrowDistance

				-- Set position relative to screen center
				arrow.Position = screenCenter + Vector2.new(arrowX, arrowY)
				
				-- Rotate arrow to point towards target
				arrow.Rotation = math.deg(relativeAngle) + 90
				arrow.Visible = true
			else
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:Toggle(state)
		enabled = state
		ArrowsESP.Enabled = enabled
		if not enabled then
			for _, arrow in pairs(arrowPool) do
				arrow.Visible = false
			end
		end
	end

	function ArrowsESP:SetTeamFilter(state)
		teamFilter = not not state
	end

	function ArrowsESP:SetColor(r, g, b)
		ArrowColor = Color3.new(r, g, b)
		for _, arrow in pairs(arrowPool) do
			arrow.Color = ArrowColor
		end
	end

	function ArrowsESP:SetDistance(dist)
		ArrowDistance = dist
	end

	function ArrowsESP:SetSize(size)
		ArrowSize = size
		for _, arrow in pairs(arrowPool) do
			arrow.Size = ArrowSize
		end
	end

	ArrowsESP.Connection = RunService.RenderStepped:Connect(updateArrows)
end

-- ===== CHAMS ESP ===== (unchanged)
local ChamsESP = {}
do
	local chamFolder = Instance.new("Folder")
	chamFolder.Name = "Op1Hax_Chams"
	chamFolder.Parent = CoreGui

	local chamCache = {}
	local enabled = false
	local teamFilter = true
	local outlineColor = Color3.new(1, 1, 1)
	local outlineTransparency = 0.8

	ChamsESP.Enabled = enabled

	local function createCham(player)
		if not player.Character then return end
		if chamCache[player] then return end

		local highlight = Instance.new("Highlight")
		highlight.Adornee = player.Character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 1
		highlight.OutlineColor = outlineColor
		highlight.OutlineTransparency = outlineTransparency
		highlight.Parent = chamFolder

		chamCache[player] = highlight
	end

	local function removeCham(player)
		if chamCache[player] then
			chamCache[player]:Destroy()
			chamCache[player] = nil
		end
	end

	local function updateChams()
		if not enabled or not LocalPlayer.Character then return end

		for _, player in pairs(ConcurrentPlayers) do
			if player == LocalPlayer then
				removeCham(player)
			else
				if player.Character then
					if teamFilter and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
						removeCham(player)
					else
						createCham(player)
					end
				else
					removeCham(player)
				end
			end
		end
	end

	function ChamsESP:Toggle(state)
		enabled = state
		ChamsESP.Enabled = enabled
		if not enabled then
			for player in pairs(chamCache) do
				removeCham(player)
			end
		end
		print("Chams ESP toggled " .. tostring(state))
	end

	function ChamsESP:SetTeamFilter(state)
		teamFilter = not not state
		updateChams()
	end

	function ChamsESP:SetColor(r, g, b)
		outlineColor = Color3.new(r, g, b)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineColor = outlineColor
		end
	end

	function ChamsESP:SetTransparency(val)
		outlineTransparency = math.clamp(val, 0, 1)
		for _, highlight in pairs(chamCache) do
			highlight.OutlineTransparency = outlineTransparency
		end
	end

	ChamsESP.UpdateConnection = RunService.Heartbeat:Connect(updateChams)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.P then
		ArrowsESP:Toggle(not ArrowsESP.Enabled)
	elseif input.KeyCode == Enum.KeyCode.L then
		ChamsESP:Toggle(true)
		task.wait(1)
		ChamsESP:Toggle(false)
	end
end)

