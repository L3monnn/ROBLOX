-- Variables
getgenv().Shmimble = false;
getgenv().autoCoin = false;
-- Functions
function Shmimble()
	spawn(function()
		while getgenv().Shmimble == true do
			local p = game.Players.LocalPlayer.Character.HumanoidRootPart
			local s = game.workspace.Dabloons.Dabloons
			wait()
			p.CFrame = s.CFrame
			wait(1)
			firetouchinterest(workspace.Shmimble.Dabloons.Dabloons)
			wait(1)
			p.CFrame = s.CFrame
			wait(1)
			firetouchinterest(workspace.Shmimble.Dabloons.Dabloons)
		end
	end)
end

function autoCoin()
	spawn(function()
		while getgenv().autoCoin == true do
			wait(0.1)
			for i,v in pairs(workspace.Dabloons:GetDescendants()) do
				if v:IsA("UnionOperation") then
				v.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame
				wait(0.1)
				end
			end
		end
	end)
end
